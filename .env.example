# GALO configuration — copy to .env and fill in. All vars are GALO_-prefixed.

# --- Ollama (self-hosted model node) ---
GALO_OLLAMA_BASE_URL=http://zuselk-node-001.tru.zt:11434
GALO_GEN_MODEL=gemma3
# Use a dedicated embedding model if the node serves one; else the gen model.
GALO_EMBED_MODEL=nomic-embed-text
# MUST match the embedding model's output dimension. Pins the pgvector column.
GALO_EMBED_DIM=768
GALO_MODEL_TIMEOUT_S=60

# --- Postgres + pgvector (self-hosted) ---
GALO_PG_DSN=postgresql://galo:galo@localhost:5432/galo

# --- Neo4j (Community Edition, self-hosted) ---
GALO_NEO4J_URI=bolt://localhost:7687
GALO_NEO4J_USER=neo4j
GALO_NEO4J_PASSWORD=neo4j

# --- Retrieval tuning ---
GALO_RETRIEVE_K=10
GALO_GRAPH_HOPS=2
GALO_RRF_K=60

# --- Chunking ---
GALO_CHUNK_SIZE=800
GALO_CHUNK_OVERLAP=120

# --- Server ---
GALO_HOST=0.0.0.0
GALO_PORT=8000
GALO_LOG_LEVEL=INFO
